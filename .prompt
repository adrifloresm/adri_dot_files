#!/bin/bash
# ~/.prompt: custom, git-aware PS1 for interactive bash shells.
# Sourced from ~/.bashrc. Defines a PROMPT_COMMAND that rebuilds PS1 before
# every prompt, so colors reflect the live git state of the current dir.

###############################################################################
# ANSI color palette
###############################################################################
# Each entry is an escape sequence wrapped in `\[ ... \]`. The brackets are
# a readline hint: "these bytes don't advance the cursor". Without them, bash
# miscounts prompt width and wraps long command lines onto the wrong column.
#
# Escape format: \033[<attr>;<color>m
#   attr: 0 regular, 1 bold, 4 underline, 40-47 background
#   color: 30 black, 31 red, 32 green, 33 yellow, 34 blue, 35 purple, 36 cyan, 37 white

# Regular (attr 0 = normal weight)
regblk='\[\033[0;30m\]' # Black
regred='\[\033[0;31m\]' # Red
reggrn='\[\033[0;32m\]' # Green
regylw='\[\033[0;33m\]' # Yellow
regblu='\[\033[0;34m\]' # Blue
regpur='\[\033[0;35m\]' # Purple
regcyn='\[\033[0;36m\]' # Cyan
regwht='\[\033[0;37m\]' # White

# Bold (attr 1 = bright/bold)
bldblk='\[\033[1;30m\]' # Black
bldred='\[\033[1;31m\]' # Red
bldgrn='\[\033[1;32m\]' # Green
bldylw='\[\033[1;33m\]' # Yellow
bldblu='\[\033[1;34m\]' # Blue
bldpur='\[\033[1;35m\]' # Purple
bldcyn='\[\033[1;36m\]' # Cyan
bldwht='\[\033[1;37m\]' # White

# Underline (attr 4)
undblk='\[\033[4;30m\]' # Black
undred='\[\033[4;31m\]' # Red
undgrn='\[\033[4;32m\]' # Green
undylw='\[\033[4;33m\]' # Yellow
undblu='\[\033[4;34m\]' # Blue
undpur='\[\033[4;35m\]' # Purple
undcyn='\[\033[4;36m\]' # Cyan
undwht='\[\033[4;37m\]' # White

# Background (attr 40-47)
bakblk='\[\033[40m\]'   # Black
bakred='\[\033[41m\]'   # Red
bakgrn='\[\033[42m\]'   # Green
bakylw='\[\033[43m\]'   # Yellow
bakblu='\[\033[44m\]'   # Blue
bakpur='\[\033[45m\]'   # Purple
bakcyn='\[\033[46m\]'   # Cyan
bakwht='\[\033[47m\]'   # White

# Reset: return terminal to default colors. Always place at the end of a
# colored segment, otherwise subsequent output inherits the color.
rstrst='\[\033[0m\]'    # Reset

###############################################################################
# set_ps1 — rebuild PS1 based on current dir + git state
###############################################################################
# This runs via PROMPT_COMMAND (set below), which bash executes just before
# drawing each prompt. So every command gets an up-to-date branch color:
# clean (green) vs staged (yellow) vs unstaged-dirty (red).
function set_ps1() {
    # Chroot prefix — shown only if /etc/debian_chroot exists (see below).
    PS1="${debian_chroot:+($debian_chroot)}"

    # User@host — red for root (visual "danger!" cue), green for regular users.
    if [ "$USER" = root ]; then
        PS1+="$bldred\u$bldgrn@\h"
    else
        PS1+="$bldgrn\u@\h"
    fi

    # Reset color, add `:`, then blue working directory (\w = $PWD, with $HOME
    # abbreviated to ~). Reset again so the next segment picks its own color.
    PS1+="$rstrst:$bldblu\w$rstrst"

    ###########################################################################
    # Git branch detection
    # Adapted from https://github.com/jimeh/git-aware-prompt/
    ###########################################################################
    # git rev-parse --abbrev-ref HEAD prints the current branch name, or
    # "HEAD" when in detached-HEAD state. stderr is discarded so non-git
    # dirs produce no output (and the `if` sees a non-zero exit).
    local branch
    if branch=$(git rev-parse --abbrev-ref HEAD 2> /dev/null); then
        if [[ "$branch" == "HEAD" ]]; then
            branch="DETACHED"
        fi
    else
        unset branch
    fi

    # Only append the branch segment if we're inside a git repo.
    if [[ "$branch" != "" ]]; then
        # Why two git calls instead of `git status --porcelain`?
        #   diff-files (worktree vs index)   -> unstaged changes
        #   diff-index --cached HEAD (index vs HEAD) -> staged changes
        # Both are cheap plumbing commands that skip `status`'s rename
        # detection and formatting, so they're fast even in large repos.
        # Colors:
        #   red    -> unstaged changes (highest priority)
        #   yellow -> staged but not committed
        #   green  -> clean
        local branch_color
        if ! git diff-files --quiet; then
            branch_color="$bldred"
        elif ! git diff-index --quiet --cached HEAD; then
            branch_color="$bldylw"
        else
            branch_color="$bldgrn"
        fi

        PS1+="$rstrst($branch_color$branch$rstrst)"
    fi

    # Trailing `$ ` (or `# ` for root, thanks to bash's \$ expansion).
    PS1+="\$ "
}
# Run set_ps1 before every prompt draw, so git state stays live.
PROMPT_COMMAND=set_ps1

###############################################################################
# Chroot indicator
###############################################################################
# debian_chroot is a convention: /etc/debian_chroot holds a short name
# shown in the prompt so you can tell you're inside a chroot jail. Empty
# outside chroots, so the `${debian_chroot:+...}` expansion adds nothing.
if [ -z "${debian_chroot:-}" ] && [ -r /etc/debian_chroot ]; then
    debian_chroot=$(cat /etc/debian_chroot)
fi

###############################################################################
# xterm title
###############################################################################
# Sets the terminal window/tab title to "user@host: cwd" using the OSC 0
# escape: ESC ] 0 ; <title> BEL. Wrapped in \[ \] so it doesn't advance the
# cursor. This PREPENDS to PS1, so it fires every prompt (keeping title in
# sync with directory changes).
case "$TERM" in
    xterm*|rxvt*)
        PS1="\[\e]0;${debian_chroot:+($debian_chroot)}\u@\h: \w\a\]$PS1"
        ;;
    *)
        ;;
esac
